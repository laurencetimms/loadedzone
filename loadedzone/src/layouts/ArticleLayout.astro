---
interface Props {
  title: string;
  description: string;
  type: 'article' | 'guide';
  backLink?: string;
  backLabel?: string;
}

import BaseLayout from './BaseLayout.astro';

const {
  title,
  description,
  type,
  backLink = type === 'article' ? '/learn' : '/guides',
  backLabel = type === 'article' ? 'All articles' : 'All guides',
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="mb-10">
      <a href={backLink} class="text-sm text-zone hover:text-zone-dark transition-colors mb-4 inline-block">
        ← {backLabel}
      </a>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-stone-900 tracking-tight leading-tight">
        {title}
      </h1>
      {type === 'guide' && (
        <p class="mt-3 text-sm font-medium text-stone-400 uppercase tracking-wider">Quick Guide</p>
      )}
    </div>

    <div class="prose-custom">
      <slot />
    </div>
  </article>

  <style>
    .prose-custom {
      color: var(--color-stone-700);
      line-height: 1.75;
      font-size: 1.0625rem;
    }
    .prose-custom h2 {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-stone-900);
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
    }
    .prose-custom h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--color-stone-800);
      margin-top: 2rem;
      margin-bottom: 0.5rem;
    }
    .prose-custom p {
      margin-bottom: 1.25rem;
    }
    .prose-custom a {
      color: var(--color-zone);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .prose-custom a:hover {
      color: var(--color-zone-dark);
    }
    .prose-custom strong {
      color: var(--color-stone-900);
      font-weight: 600;
    }
    .prose-custom ul, .prose-custom ol {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }
    .prose-custom li {
      margin-bottom: 0.5rem;
    }
    .prose-custom blockquote {
      border-left: 3px solid var(--color-zone);
      padding-left: 1rem;
      margin: 1.5rem 0;
      color: var(--color-stone-600);
      font-style: italic;
    }
    .prose-custom .callout {
      background: color-mix(in srgb, var(--color-zone) 5%, white);
      border: 1px solid color-mix(in srgb, var(--color-zone) 20%, white);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
    }
    .prose-custom .callout-warn {
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
    }
    .prose-custom .citation {
      font-size: 0.8rem;
      color: var(--color-stone-400);
      margin-top: -0.75rem;
      margin-bottom: 1.25rem;
    }
    .prose-custom .key-takeaway {
      background: var(--color-stone-100);
      border-radius: 0.75rem;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      border-left: 4px solid var(--color-zone);
    }
    .prose-custom .key-takeaway p {
      margin-bottom: 0.5rem;
    }
    .prose-custom .key-takeaway p:last-child {
      margin-bottom: 0;
    }
  </style>
</BaseLayout>
